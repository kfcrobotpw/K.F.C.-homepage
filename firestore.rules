rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Global Safety Net (Default Deny)
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn();
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Root bootstrapped admin & ABAC role checking
    function isOfficer() {
      return isSignedIn() && (
        request.auth.token.email == "kfcrobotpw@gmail.com" ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isOfficer == true)
      );
    }

    function canManageNotice(uid) {
      return (request.auth.token.email == "kfcrobotpw@gmail.com") || (
        exists(/databases/$(database)/documents/users/$(uid)) &&
        get(/databases/$(database)/documents/users/$(uid)).data.get('canManageNotice', false) == true
      );
    }

    function canManageResource(uid) {
      return (request.auth.token.email == "kfcrobotpw@gmail.com") || (
        exists(/databases/$(database)/documents/users/$(uid)) &&
        get(/databases/$(database)/documents/users/$(uid)).data.get('canManageResource', false) == true
      );
    }

    function canManageCalendar(uid) {
      return (request.auth.token.email == "kfcrobotpw@gmail.com") || (
        exists(/databases/$(database)/documents/users/$(uid)) &&
        get(/databases/$(database)/documents/users/$(uid)).data.get('canManageCalendar', false) == true
      );
    }

    function canManageExecutive(uid) {
      return (request.auth.token.email == "kfcrobotpw@gmail.com") || (
        exists(/databases/$(database)/documents/users/$(uid)) &&
        get(/databases/$(database)/documents/users/$(uid)).data.get('canManageExecutive', false) == true
      );
    }

    // Schema Validators
    function isValidUser(data) {
      return data.keys().hasAll(['id', 'email', 'displayName', 'photoURL', 'isOfficer']) &&
             data.keys().size() >= 5 && data.keys().size() <= 9 &&
             data.id is string &&
             data.email is string &&
             data.displayName is string &&
             data.photoURL is string &&
             data.isOfficer is bool &&
             (!data.keys().contains('canManageNotice') || data.canManageNotice is bool) &&
             (!data.keys().contains('canManageResource') || data.canManageResource is bool) &&
             (!data.keys().contains('canManageCalendar') || data.canManageCalendar is bool) &&
             (!data.keys().contains('canManageExecutive') || data.canManageExecutive is bool);
    }

    function isValidNotice(data) {
      return data.keys().hasAll(['id', 'title', 'content', 'authorId', 'authorName', 'authorPhoto', 'createdAt', 'hasPoll']) &&
             data.id is string &&
             data.title is string && data.title.size() <= 100 &&
             data.content is string && data.content.size() <= 50000 &&
             data.authorId == request.auth.uid &&
             data.authorName is string &&
             data.authorPhoto is string &&
             data.hasPoll is bool &&
             (!data.keys().contains('files') || data.files is list) &&
             (!data.keys().contains('links') || data.links is list);
    }

    function isValidLike(data) {
      return data.keys().hasAll(['userId', 'createdAt']) &&
             data.keys().size() == 2 &&
             data.userId == request.auth.uid;
    }

    function isValidComment(data) {
      return data.keys().hasAll(['id', 'noticeId', 'content', 'authorId', 'authorName', 'authorPhoto', 'createdAt']) &&
             data.keys().size() == 7 &&
             data.id is string &&
             data.noticeId is string &&
             data.content is string && data.content.size() <= 2000 &&
             data.authorId == request.auth.uid &&
             data.authorName is string &&
             data.authorPhoto is string;
    }

    function isValidVote(data) {
      return data.keys().hasAll(['userId', 'optionIndex', 'createdAt']) &&
             data.keys().size() == 3 &&
             data.userId == request.auth.uid &&
             data.optionIndex is int;
    }

    function isValidResource(data) {
      return data.keys().hasAll(['id', 'title', 'description', 'authorId', 'authorName', 'authorPhoto', 'createdAt']) &&
             data.id is string &&
             data.title is string && data.title.size() <= 100 &&
             data.description is string && data.description.size() <= 5000 &&
             data.authorId == request.auth.uid &&
             data.authorName is string &&
             data.authorPhoto is string;
    }

    function isValidSchedule(data) {
      return data.keys().hasAll(['id', 'title', 'description', 'startDate', 'endDate', 'color', 'authorId', 'createdAt']) &&
             data.keys().size() == 8 &&
             data.id is string &&
             data.title is string && data.title.size() <= 100 &&
             data.description is string && data.description.size() <= 2000 &&
             data.startDate is string &&
             data.endDate is string &&
             data.color is string &&
             data.authorId == request.auth.uid;
    }

    function isValidExecutive(data) {
      return data.keys().hasAll(['id', 'name', 'role', 'description', 'photoUrl', 'createdAt']) &&
             data.id is string &&
             data.name is string && data.name.size() <= 40 &&
             data.role is string && data.role.size() <= 40 &&
             data.description is string && data.description.size() <= 1000 &&
             data.photoUrl is string;
    }

    function isValidChatMessage(data) {
      return data.keys().hasAll(['id', 'content', 'senderId', 'senderName', 'senderPhoto', 'createdAt']) &&
             data.keys().size() == 6 &&
             data.id is string &&
             data.content is string && data.content.size() <= 2500 &&
             data.senderId == request.auth.uid &&
             data.senderName is string && data.senderName.size() <= 100 &&
             data.senderPhoto is string &&
             data.createdAt == request.time;
    }

    // --- Collection Routes ---

    // 1. Users Collection
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId && isValidUser(incoming()) && (
        incoming().isOfficer == false || 
        request.auth.token.get('email', '') == "kfcrobotpw@gmail.com"
      );
      allow update: if isSignedIn() && (
        // Root admin can modify anything on their own profile
        (request.auth.uid == userId && request.auth.token.get('email', '') == "kfcrobotpw@gmail.com" && isValidUser(incoming())) ||
        // Officers can modify anyone's properties
        isOfficer() ||
        // Profile owner can modify own details EXCEPT isOfficer and permission fields
        (request.auth.uid == userId && isValidUser(incoming()) && 
         incoming().isOfficer == existing().isOfficer &&
         incoming().get('canManageNotice', false) == existing().get('canManageNotice', false) &&
         incoming().get('canManageResource', false) == existing().get('canManageResource', false) &&
         incoming().get('canManageCalendar', false) == existing().get('canManageCalendar', false) &&
         incoming().get('canManageExecutive', false) == existing().get('canManageExecutive', false))
      );
      allow delete: if isOfficer();
    }

    // 2. Notices Collection
    match /notices/{noticeId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if canManageNotice(request.auth.uid) && isValidId(noticeId) && isValidNotice(incoming());
      allow update: if canManageNotice(request.auth.uid) && isValidNotice(incoming());
      allow delete: if canManageNotice(request.auth.uid);

      // Subcollection: Likes
      match /likes/{userId} {
        allow read: if isSignedIn();
        allow create, delete: if isSignedIn() && request.auth.uid == userId && (request.method == 'delete' || isValidLike(incoming()));
      }

      // Subcollection: Comments
      match /comments/{commentId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && isValidId(commentId) && isValidComment(incoming());
        allow update: if isSignedIn() && existing().authorId == request.auth.uid && isValidComment(incoming());
        allow delete: if isSignedIn() && (existing().authorId == request.auth.uid || canManageNotice(request.auth.uid));
      }

      // Subcollection: Votes
      match /votes/{userId} {
        allow read: if isSignedIn();
        allow create, update: if isSignedIn() && request.auth.uid == userId && isValidVote(incoming());
        allow delete: if isSignedIn() && request.auth.uid == userId;
      }
    }

    // 3. Resources Collection
    match /resources/{resourceId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(resourceId) && isValidResource(incoming());
      allow update: if isSignedIn() && (existing().authorId == request.auth.uid || canManageResource(request.auth.uid)) && isValidResource(incoming());
      allow delete: if isSignedIn() && (existing().authorId == request.auth.uid || canManageResource(request.auth.uid));
    }

    // 4. Schedules Collection
    match /schedules/{scheduleId} {
      allow read: if isSignedIn();
      allow create: if canManageCalendar(request.auth.uid) && isValidId(scheduleId) && isValidSchedule(incoming());
      allow update: if canManageCalendar(request.auth.uid) && isValidSchedule(incoming());
      allow delete: if canManageCalendar(request.auth.uid);
    }

    // 5. Executives Collection
    match /executives/{executiveId} {
      allow read: if isSignedIn();
      allow create: if canManageExecutive(request.auth.uid) && isValidId(executiveId) && isValidExecutive(incoming());
      allow update: if canManageExecutive(request.auth.uid) && isValidExecutive(incoming());
      allow delete: if canManageExecutive(request.auth.uid);
    }

    // 6. Officer Messages Collection (Executive Chat)
    match /officer_messages/{messageId} {
      allow get, list: if isOfficer();
      allow create: if isOfficer() && isValidId(messageId) && isValidChatMessage(incoming());
      allow update: if false; // Messages are immutable
      allow delete: if isOfficer() && (existing().senderId == request.auth.uid || request.auth.token.email == "kfcrobotpw@gmail.com");
    }
  }
}
